# whitelist mode: ignore everything by default
*

# keep root tracked files
!/.gitattributes
!/.gitignore
!/.mcp.json
!/README.md
!/install.sh
!/package.template.json
!/.github/
!/.github/workflows/
!/.github/workflows/*.yml
!/tooling/
!/tooling/*.json
!/.guide/
!/.guide/AGENTS.md
!/.guide/CLAUDE.md
!/.guide/architecture.mmd
!/.guide/tools.md
!/.guide/profiles/
!/.guide/profiles/*.md
!/.guide/profiles/tools/
!/.guide/profiles/tools/*.md
!/.guide/profiles/runtime/
!/.guide/profiles/runtime/*.md
!/.guide/profiles/identity/
!/.guide/profiles/identity/*.md
!/.guide/profiles/providers/
!/.guide/profiles/providers/*.md
!/.guide/principles/
!/.guide/principles/*.md
!/.guide/principles/runtime/
!/.guide/principles/runtime/*.md
!/.guide/principles/roles/
!/.guide/principles/roles/*.md
!/.guide/principles/domains/
!/.guide/principles/domains/*.md

# keep tracked .claude files only
!/.claude/
/.claude/*
!/.claude/commands/
!/.claude/scripts/
!/.claude/templates/
!/.claude/settings.json
/.claude/commands/*
!/.claude/commands/*.md
/.claude/scripts/*
!/.claude/scripts/*.sh
/.claude/templates/*
!/.claude/templates/cloudflare/
!/.claude/templates/electron/
!/.claude/templates/python/
/.claude/templates/cloudflare/*
/.claude/templates/electron/*
/.claude/templates/python/*
!/.claude/templates/cloudflare/common/
!/.claude/templates/cloudflare/release-pr.yml
!/.claude/templates/cloudflare/pages/
!/.claude/templates/cloudflare/workers/
/.claude/templates/cloudflare/common/*
/.claude/templates/cloudflare/pages/*
/.claude/templates/cloudflare/workers/*
!/.claude/templates/cloudflare/common/*
!/.claude/templates/cloudflare/pages/*
!/.claude/templates/cloudflare/workers/*
!/.claude/templates/electron/*
!/.claude/templates/python/*

# keep tracked .codex files only
!/.codex/
/.codex/*
!/.codex/config.toml
!/.codex/rules/
!/.codex/rules/default.rules
!/.codex/skills/

# top-level skills: keep only SKILL.md
!/.codex/skills/*/
/.codex/skills/*/*
!/.codex/skills/*/SKILL.md

# system skills: keep only tracked slides/spreadsheets trees
/.codex/skills/.system/*
!/.codex/skills/.system/slides/
!/.codex/skills/.system/spreadsheets/
!/.codex/skills/.system/slides/**
!/.codex/skills/.system/spreadsheets/**
