{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__serena__*",
      "Bash(bun run prettier*)",
      "Bash(bun run format*)",
      "Bash(bun run lint*)",
      "Bash(bun run typecheck*)",
      "Bash(bun run tsc*)",
      "Bash(bun run build*)",
      "Bash(bun run test*)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git fetch origin)",
      "Bash(git add *)",
      "Bash(git pull --ff-only *)",
      "Bash(git branch *)",
      "Bash(git ls-files *)",
      "Bash(git push -u origin *)",
      "Bash(git -C * push -u origin *)",
      "Bash(git checkout *)",
      "Bash(git push origin --delete *)",
      "Bash(ls*)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(git commit *)",
      "Bash(gh --version)",
      "Bash(gh auth status)",
      "Bash(gh repo view *)",
      "Bash(gh repo create *)",
      "Bash(gh repo edit *)",
      "Bash(gh api *)",
      "Bash(gh pr *)",
      "Bash(gh pr create *)",
      "Bash(gh run *)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(npx wrangler dev*)",
      "Bash(npx wrangler whoami)",
      "Bash(npx wrangler --version)",
      "Bash(bun install*)",
      "Bash(bun run deploy:staging)"
    ],
    "ask": [
      
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(curl *)",
      "Bash(rm -rf *)",

      "Bash(bun add*)"
    ],
    "deny": [
      "Bash(wget *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(wrangler deploy*)",
      "Bash(npx wrangler deploy*)",
      "Bash(bunx wrangler deploy*)",
      "Bash(npm run deploy*)",
      "Bash(wrangler pages deploy*)",
      "Bash(npx wrangler pages deploy*)",
      "Bash(bunx wrangler pages deploy*)"
    ]
  }
}
