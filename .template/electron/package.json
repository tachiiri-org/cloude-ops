{
  "name": "__APP_NAME__",
  "version": "0.1.1",
  "private": true,
  "description": "__APP_DESCRIPTION__",
  "type": "module",
  "main": "out/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/__REPO_OWNER__/__REPO_NAME__.git"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:linux": "electron-builder --linux AppImage --publish never",
    "preview": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:ui": "bash scripts/run-ui-smoke.sh",
    "test:update": "bash scripts/run-update-smoke.sh",
    "test:update:release": "bash scripts/run-release-update-check.sh",
    "validate": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run build && bun run test:ui && bun run test:update"
  },
  "build": {
    "appId": "__APP_ID__",
    "productName": "__APP_NAME__",
    "electronUpdaterCompatibility": ">=2.16",
    "electronLanguages": [
      "en-US",
      "ja"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "artifactName": "__APP_NAME__-${version}-${env.APP_CHANNEL}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "__REPO_OWNER__",
        "repo": "__REPO_NAME__",
        "private": false,
        "channel": "${env.APP_UPDATE_CHANNEL}"
      }
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.10",
    "vitest": "^4.0.18"
  }
}
