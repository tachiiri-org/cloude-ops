# allow: read-only git
prefix_rule(pattern=["git", "status"], decision="allow")
prefix_rule(pattern=["git", "diff"], decision="allow")
prefix_rule(pattern=["git", "log"], decision="allow")
prefix_rule(pattern=["git", "show"], decision="allow")
prefix_rule(pattern=["git", "fetch", "origin"], decision="allow")

# allow: git write (safe)
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "push", "-u", "origin"], decision="allow")
prefix_rule(pattern=["git", "-C"], decision="allow")
prefix_rule(pattern=["git", "push", "origin", "--delete"], decision="allow")

# prompt: git destructive
prefix_rule(pattern=["git", "push"], decision="prompt")
prefix_rule(pattern=["git", "checkout"], decision="prompt")
prefix_rule(pattern=["git", "rebase"], decision="prompt")
prefix_rule(pattern=["git", "reset"], decision="prompt")

# allow: bun
prefix_rule(pattern=["bun", "install"], decision="allow")
prefix_rule(pattern=["bun", "run", "prettier"], decision="allow")
prefix_rule(pattern=["bun", "run", "format"], decision="allow")
prefix_rule(pattern=["bun", "run", "lint"], decision="allow")
prefix_rule(pattern=["bun", "run", "typecheck"], decision="allow")
prefix_rule(pattern=["bun", "run", "tsc"], decision="allow")
prefix_rule(pattern=["bun", "run", "build"], decision="allow")
prefix_rule(pattern=["bun", "run", "test"], decision="allow")
prefix_rule(pattern=["bun", "run", "deploy:staging"], decision="allow")

# prompt: bun add (dependency change)
prefix_rule(pattern=["bun", "add"], decision="prompt")

# allow: read-only shell
prefix_rule(pattern=["ls"], decision="allow")
prefix_rule(pattern=["cat"], decision="allow")
prefix_rule(pattern=["rg"], decision="allow")
prefix_rule(pattern=["grep"], decision="allow")

# allow: wrangler dev/info only
prefix_rule(pattern=["npx", "wrangler", "dev"], decision="allow")
prefix_rule(pattern=["npx", "wrangler", "whoami"], decision="allow")
prefix_rule(pattern=["npx", "wrangler", "--version"], decision="allow")

# prompt: network / destructive shell
prefix_rule(pattern=["curl"], decision="prompt")
prefix_rule(pattern=["rm", "-rf"], decision="prompt")

# forbidden: production deploy
prefix_rule(pattern=["wrangler", "deploy"], decision="forbidden", justification="deploy only via merge to main")
prefix_rule(pattern=["npx", "wrangler", "deploy"], decision="forbidden", justification="deploy only via merge to main")
prefix_rule(pattern=["bunx", "wrangler", "deploy"], decision="forbidden", justification="deploy only via merge to main")
prefix_rule(pattern=["npm", "run", "deploy"], decision="forbidden", justification="deploy only via merge to main")
prefix_rule(pattern=["wrangler", "pages", "deploy"], decision="forbidden", justification="deploy only via merge to main")
prefix_rule(pattern=["npx", "wrangler", "pages", "deploy"], decision="forbidden", justification="deploy only via merge to main")
prefix_rule(pattern=["bunx", "wrangler", "pages", "deploy"], decision="forbidden", justification="deploy only via merge to main")

# forbidden: wget
prefix_rule(pattern=["wget"], decision="forbidden")
prefix_rule(pattern=["gh", "--version"], decision="allow")
prefix_rule(pattern=["gh", "auth", "status"], decision="allow")
prefix_rule(pattern=["gh", "repo", "view"], decision="allow")
prefix_rule(pattern=["gh", "repo", "create"], decision="allow")
prefix_rule(pattern=["gh", "repo", "edit"], decision="allow")
prefix_rule(pattern=["gh", "api"], decision="allow")
prefix_rule(pattern=["gh", "pr"], decision="allow")
prefix_rule(pattern=["gh", "pr", "create"], decision="allow")
prefix_rule(pattern=["node", "--input-type=module", "-e", "import { _electron as electron } from '@playwright/test'; const appPath=process.env.PACKAGED_APP_PATH; const app=await electron.launch({ executablePath: appPath, cwd: process.cwd(), env: { ...process.env, DISPLAY: ':0', APPIMAGE: appPath, APPIMAGE_EXTRACT_AND_RUN: '1' } }); try { const win=await app.firstWindow(); await win.waitForLoadState('domcontentloaded'); await win.waitForTimeout(5000); console.log(await win.content()); } finally { await app.close(); }"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "rm -rf /tmp/code-atlas-old-dev && mkdir -p /tmp/code-atlas-old-dev && cp artifacts/release-update/dev/code-atlas-0.1.0-dev.AppImage /tmp/code-atlas-old-dev/ && cd /tmp/code-atlas-old-dev && ./code-atlas-0.1.0-dev.AppImage --appimage-extract >/tmp/code-atlas-old-dev/extract.log 2>&1 && find squashfs-root -maxdepth 2 -type f | sort | sed -n '1,120p'"], decision="allow")
prefix_rule(pattern=["node", "--input-type=module", "-e", "import { _electron as electron } from '@playwright/test'; const executablePath='/tmp/code-atlas-old-dev/squashfs-root/code-atlas'; const appImage='/home/tachiiri/project/code-atlas/artifacts/release-update/dev/code-atlas-0.1.0-dev.AppImage'; const app=await electron.launch({ executablePath, cwd: '/tmp/code-atlas-old-dev/squashfs-root', env: { ...process.env, DISPLAY: ':0', APPIMAGE: appImage } }); try { const win=await app.firstWindow(); await win.waitForLoadState('domcontentloaded'); await win.waitForTimeout(5000); console.log(await win.locator('h1').textContent()); console.log('channel:' + await win.locator('#app-channel').textContent()); console.log('status:' + await win.locator('#update-status').textContent()); console.log('message:' + await win.locator('#update-message').textContent()); console.log('latest:' + await win.locator('#update-latest-version').textContent()); } finally { await app.close(); }"], decision="allow")
prefix_rule(pattern=["gh", "release", "view", "update-dev", "--json", "url,isDraft,isPrerelease"], decision="allow")
prefix_rule(pattern=["gh", "run", "list", "--workflow", "publish-electron.yml", "--branch", "main", "--limit", "1", "--json", "databaseId,status,conclusion,url"], decision="allow")
prefix_rule(pattern=["gh", "run", "watch", "23105367976"], decision="allow")
prefix_rule(pattern=["bash", "scripts/run-release-update-check.sh"], decision="allow")
prefix_rule(pattern=["gh", "release", "view", "update-dev", "--json", "assets"], decision="allow")
prefix_rule(pattern=["gh", "release", "view", "update-stable", "--json", "assets"], decision="allow")
prefix_rule(pattern=["gh", "run", "watch", "23105473453"], decision="allow")
prefix_rule(pattern=["gh", "run", "view", "23105473453", "--log-failed"], decision="allow")
prefix_rule(pattern=["gh", "run", "watch", "23105588853"], decision="allow")
prefix_rule(pattern=["gh", "run", "list", "--workflow", "publish-electron.yml", "--branch", "dev", "--limit", "1", "--json", "databaseId,status,conclusion,url"], decision="allow")
prefix_rule(pattern=["gh", "run", "watch", "23105644208"], decision="allow")
