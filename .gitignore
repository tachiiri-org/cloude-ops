# whitelist mode: ignore everything by default
*

# keep root tracked files
!/.gitattributes
!/.gitignore
!/.mcp.json
!/AGENTS.md
!/CLAUDE.md
!/README.md
!/architecture.mmd
!/install.sh
!/package.template.json
!/profiles/
!/profiles/*.md
!/profiles/runtime/
!/profiles/runtime/*.md
!/profiles/identity/
!/profiles/identity/*.md
!/profiles/providers/
!/profiles/providers/*.md
!/principles/
!/principles/*.md
!/principles/roles/
!/principles/roles/*.md
!/principles/domains/
!/principles/domains/*.md

# keep tracked .claude files only
!/.claude/
/.claude/*
!/.claude/commands/
!/.claude/scripts/
!/.claude/settings.json
/.claude/commands/*
!/.claude/commands/*.md
/.claude/scripts/*
!/.claude/scripts/*.sh

# keep tracked .codex files only
!/.codex/
/.codex/*
!/.codex/config.toml
!/.codex/rules/
!/.codex/rules/default.rules
!/.codex/skills/

# top-level skills: keep only SKILL.md
!/.codex/skills/*/
/.codex/skills/*/*
!/.codex/skills/*/SKILL.md

# system skills: keep only tracked slides/spreadsheets trees
/.codex/skills/.system/*
!/.codex/skills/.system/slides/
!/.codex/skills/.system/spreadsheets/
!/.codex/skills/.system/slides/**
!/.codex/skills/.system/spreadsheets/**
