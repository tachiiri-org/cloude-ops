# whitelist mode: ignore everything by default
*

# keep root tracked files
!/.gitattributes
!/.gitignore
!/.mcp.json
!/README.md
!/install.sh
!/package.template.json
!/.github/
!/.github/workflows/
!/.github/workflows/*.yml
!/tooling/
!/tooling/*.json
!/.guide/
!/.guide/AGENTS.md
!/.guide/CLAUDE.md
!/.guide/architecture.mmd
!/.guide/foundations.md
!/.guide/boundaries/
!/.guide/boundaries/*.md
!/.guide/compatibility/
!/.guide/compatibility/*.md
!/.guide/data/
!/.guide/data/*.md
!/.guide/governance/
!/.guide/governance/*.md
!/.guide/identity/
!/.guide/identity/*.md
!/.guide/observability/
!/.guide/observability/*.md
!/.guide/operations/
!/.guide/operations/*.md
!/.guide/roles/
!/.guide/roles/*.md
!/.guide/hosts/
!/.guide/hosts/*.md
!/.guide/runtimes/
!/.guide/runtimes/*.md
!/.guide/languages/
!/.guide/languages/*.md
!/.guide/tools/
!/.guide/tools/*.md
!/.guide/providers/
!/.guide/providers/*.md
!/.guide/tenancy/
!/.guide/tenancy/*.md

# keep tracked .claude files only
!/.claude/
/.claude/*
!/.claude/commands/
!/.claude/scripts/
!/.claude/templates/
!/.claude/settings.json
/.claude/commands/*
!/.claude/commands/*.md
/.claude/scripts/*
!/.claude/scripts/*.sh
/.claude/templates/*
!/.claude/templates/cloudflare/
!/.claude/templates/electron/
!/.claude/templates/python/
/.claude/templates/cloudflare/*
/.claude/templates/electron/*
/.claude/templates/python/*
!/.claude/templates/cloudflare/common/
!/.claude/templates/cloudflare/release-pr.yml
!/.claude/templates/cloudflare/pages/
!/.claude/templates/cloudflare/workers/
/.claude/templates/cloudflare/common/*
/.claude/templates/cloudflare/pages/*
/.claude/templates/cloudflare/workers/*
!/.claude/templates/cloudflare/common/*
!/.claude/templates/cloudflare/pages/*
!/.claude/templates/cloudflare/workers/*
!/.claude/templates/electron/*
!/.claude/templates/python/*

# keep tracked .codex files only
!/.codex/
/.codex/*
!/.codex/config.toml
!/.codex/rules/
!/.codex/rules/default.rules
!/.codex/skills/

# top-level skills: keep only SKILL.md
!/.codex/skills/*/
/.codex/skills/*/*
!/.codex/skills/*/SKILL.md

# system skills: keep only tracked slides/spreadsheets trees
/.codex/skills/.system/*
!/.codex/skills/.system/slides/
!/.codex/skills/.system/spreadsheets/
!/.codex/skills/.system/slides/**
!/.codex/skills/.system/spreadsheets/**
