# whitelist mode: ignore everything by default
*

# keep root tracked files
!/.gitattributes
!/.gitignore
!/.mcp.json
!/install.sh
!/package.template.json
!/.github/
!/.github/workflows/
!/.github/workflows/*.yml
!/tooling/
!/tooling/*.json
!/project/
/project/*
!/project/.guide/
!/project/.guide/AGENTS.md
!/project/.guide/CLAUDE.md
!/project/.guide/architecture.mmd
!/project/.guide/principles.md
!/project/.guide/boundaries/
!/project/.guide/boundaries/*.md
!/project/.guide/compatibility/
!/project/.guide/compatibility/*.md
!/project/.guide/data/
!/project/.guide/data/*.md
!/project/.guide/governance/
!/project/.guide/governance/*.md
!/project/.guide/identity/
!/project/.guide/identity/*.md
!/project/.guide/implementation/
!/project/.guide/implementation/*.md
!/project/.guide/observability/
!/project/.guide/observability/*.md
!/project/.guide/operations/
!/project/.guide/operations/*.md
!/project/.guide/roles/
!/project/.guide/roles/*.md
!/project/.guide/hosts/
!/project/.guide/hosts/*.md
!/project/.guide/runtimes/
!/project/.guide/runtimes/*.md
!/project/.guide/languages/
!/project/.guide/languages/*.md
!/project/.guide/tools/
!/project/.guide/tools/*.md
!/project/.guide/providers/
!/project/.guide/providers/*.md
!/project/.guide/tenancy/
!/project/.guide/tenancy/*.md
!/project/.template/
/project/.template/*
!/project/.template/electron/
!/project/.template/electron/**

# keep tracked .claude files only
!/.claude/
/.claude/*
!/.claude/commands/
!/.claude/scripts/
!/.claude/templates/
!/.claude/settings.json
/.claude/commands/*
!/.claude/commands/*.md
/.claude/scripts/*
!/.claude/scripts/*.sh
/.claude/templates/*
!/.claude/templates/cloudflare/
!/.claude/templates/electron/
!/.claude/templates/python/
/.claude/templates/cloudflare/*
/.claude/templates/electron/*
/.claude/templates/python/*
!/.claude/templates/cloudflare/common/
!/.claude/templates/cloudflare/release-pr.yml
!/.claude/templates/cloudflare/pages/
!/.claude/templates/cloudflare/workers/
/.claude/templates/cloudflare/common/*
/.claude/templates/cloudflare/pages/*
/.claude/templates/cloudflare/workers/*
!/.claude/templates/cloudflare/common/*
!/.claude/templates/cloudflare/pages/*
!/.claude/templates/cloudflare/workers/*
!/.claude/templates/electron/*
!/.claude/templates/python/*

# keep tracked .codex files only
!/.codex/
/.codex/*
!/.codex/config.toml
!/.codex/rules/
!/.codex/rules/default.rules
!/.codex/skills/

# top-level skills: keep only SKILL.md
!/.codex/skills/*/
/.codex/skills/*/*
!/.codex/skills/*/SKILL.md

# system skills: keep only tracked slides/spreadsheets trees
/.codex/skills/.system/*
!/.codex/skills/.system/slides/
!/.codex/skills/.system/spreadsheets/
!/.codex/skills/.system/slides/**
!/.codex/skills/.system/spreadsheets/**
